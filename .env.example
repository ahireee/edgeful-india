# Upstox API credentials
# Get these from https://account.upstox.com/developer/apps
#
# You have two options:
#
# OPTION A — Standard OAuth flow (access token expires daily at 03:30 IST)
#   Use this if you want full API access including order placement.
#   You'll need to refresh the access token every morning before market open.
UPSTOX_CLIENT_ID=your_api_key_here
UPSTOX_CLIENT_SECRET=your_api_secret_here
UPSTOX_REDIRECT_URI=http://localhost:3000/callback
UPSTOX_ACCESS_TOKEN=        # populated by scripts/login.py after OAuth flow
#
# OPTION B — Analytics Token (1-year validity, read-only) — RECOMMENDED for this project
#   Since edgeful-india is research/backtest only, a long-lived read-only token
#   is much simpler. Generate from the developer portal under "Analytics Token".
#   If set, the data layer uses this and ignores OPTION A.
UPSTOX_ANALYTICS_TOKEN=

# Local data warehouse path
DUCKDB_PATH=./data/edgeful.duckdb

# Logging
LOG_LEVEL=INFO
